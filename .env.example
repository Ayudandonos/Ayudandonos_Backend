# Server
NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://ayudandonos:ayudandonos_dev@localhost:5432/ayudandonos

# JWT
JWT_SECRET=cambiar_por_clave_secreta_segura_en_produccion
JWT_EXPIRES_IN=7d

# CORS (separar multiples origenes con coma, sin slash final)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://ayudandonos-frontend.vercel.app,https://ayudandonos-frontend-erick-s-projects8.vercel.app

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# Seed (obligatorio en local y en Vercel)
# En cada seed/deploy se TRUNCAN las tablas de negocio y se carga solo el dataset demo.
# Ver docs/SEED.md
SEED_ADMIN_PASSWORD=cambiar_password_admin_seguro
# Password compartida de donantes y fundaciones demo (opcional)
# SEED_DEMO_PASSWORD=AyudaDemo2026!

# Vercel (inyectada automaticamente en despliegue)
# VERCEL_URL=

# Uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_MB=10
PUBLIC_BASE_URL=http://localhost:3000

# Vercel Blob (obligatorio en produccion Vercel; store PUBLIC para logos)
# Crear store en Vercel Dashboard -> Storage -> Blob -> Public
# BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS=public

# CountryStateCity (proxy de ubicaciones; nunca exponer en frontend)
CSC_API_KEY=
CSC_API_BASE_URL=https://api.countrystatecity.in/v1
CSC_CACHE_TTL_MS=86400000

# Geocoding (Nominatim / OSM; User-Agent obligatorio por politica del proveedor)
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=AyudandonosBackend/1.0 (contacto: apoyo_ud@fesc.edu.co)
GEOCODING_CACHE_TTL_MS=86400000
GEOCODING_MIN_INTERVAL_MS=1100
GEOCODING_TIMEOUT_MS=5000
