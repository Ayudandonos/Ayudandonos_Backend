generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  FOUNDATION
  ADMIN
}

enum FoundationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum FoundationDocumentType {
  RUT
  LEGAL_EXISTENCE_CERTIFICATE
  LEGAL_REPRESENTATIVE_ID
  BANK_CERTIFICATION
}

enum SocialNetworkType {
  FACEBOOK
  INSTAGRAM
  X
  LINKEDIN
  YOUTUBE
  TIKTOK
  OTHER
}

enum CampaignStatus {
  DRAFT
  PUBLISHED
  FINISHED
  CANCELLED
}

enum NeedPriority {
  LOW
  MEDIUM
  HIGH
}

enum DonationStatus {
  COMMITTED
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  CANCELLED
}

enum NotificationType {
  DONATION_CREATED
  DONATION_STATUS_CHANGED
  DONATION_MESSAGE
  DONATION_DELIVERY_UPDATED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  phone        String?
  city         String?
  department   String?
  bio          String?
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  foundation Foundation?

  foundationObservations FoundationAdminObservation[] @relation("ObservationAuthor")
  verifiedFoundations    Foundation[]                 @relation("FoundationVerifier")
  donations              Donation[]                   @relation("DonationDonor")
  donationStatusChanges  DonationStatusHistory[]      @relation("DonationStatusChanger")
  messages               Message[]
  notifications          Notification[]

  @@map("users")
}

model Foundation {
  id                          String           @id @default(uuid()) @db.Uuid
  userId                      String           @unique @map("user_id") @db.Uuid
  name                        String
  acronym                     String?
  nit                         String?          @unique
  category                    String?
  mission                     String?
  vision                      String?
  description                 String?
  city                        String?
  department                  String?
  address                     String?
  latitude                    Float?
  longitude                   Float?
  institutionalEmail          String?          @map("institutional_email")
  phone                       String?
  website                     String?
  legalRepresentativeName     String?          @map("legal_representative_name")
  legalRepresentativeDocument String?          @map("legal_representative_document")
  logoUrl                     String?          @map("logo_url")
  status                      FoundationStatus @default(PENDING)
  verifiedAt                  DateTime?        @map("verified_at")
  verifiedById                String?          @map("verified_by_id") @db.Uuid
  rejectedAt                  DateTime?        @map("rejected_at")
  suspendedAt                 DateTime?        @map("suspended_at")
  slug                        String?          @unique
  rejectionReason             String?          @map("rejection_reason")
  adminNotes                  String?          @map("admin_notes")
  deletedAt                   DateTime?        @map("deleted_at")
  createdAt                   DateTime         @default(now()) @map("created_at")
  updatedAt                   DateTime         @updatedAt @map("updated_at")

  user         User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy   User?                        @relation("FoundationVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  socialLinks  FoundationSocialLink[]
  documents    FoundationDocument[]
  observations FoundationAdminObservation[]
  campaigns    Campaign[]

  @@index([status])
  @@index([category])
  @@index([city])
  @@index([department])
  @@map("foundations")
}

model FoundationSocialLink {
  id           String            @id @default(uuid()) @db.Uuid
  foundationId String            @map("foundation_id") @db.Uuid
  network      SocialNetworkType
  url          String
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  foundation Foundation @relation(fields: [foundationId], references: [id], onDelete: Cascade)

  @@unique([foundationId, network])
  @@map("foundation_social_links")
}

model FoundationDocument {
  id           String                 @id @default(uuid()) @db.Uuid
  foundationId String                 @map("foundation_id") @db.Uuid
  type         FoundationDocumentType
  fileUrl      String                 @map("file_url")
  fileName     String                 @map("file_name")
  mimeType     String                 @map("mime_type")
  fileSize     Int                    @map("file_size")
  uploadedAt   DateTime               @default(now()) @map("uploaded_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  foundation Foundation @relation(fields: [foundationId], references: [id], onDelete: Cascade)

  @@unique([foundationId, type])
  @@map("foundation_documents")
}

model FoundationAdminObservation {
  id           String   @id @default(uuid()) @db.Uuid
  foundationId String   @map("foundation_id") @db.Uuid
  authorId     String?  @map("author_id") @db.Uuid
  content      String
  createdAt    DateTime @default(now()) @map("created_at")

  foundation Foundation @relation(fields: [foundationId], references: [id], onDelete: Cascade)
  author     User?      @relation("ObservationAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([foundationId, createdAt])
  @@map("foundation_admin_observations")
}

model Campaign {
  id                 String         @id @default(uuid()) @db.Uuid
  foundationId       String         @map("foundation_id") @db.Uuid
  title              String
  description        String
  imageUrl           String?        @map("image_url")
  status             CampaignStatus @default(DRAFT)
  startDate          DateTime?      @map("start_date")
  endDate            DateTime?      @map("end_date")
  deliveryAddress    String?        @map("delivery_address")
  deliveryLatitude   Float?         @map("delivery_latitude")
  deliveryLongitude  Float?         @map("delivery_longitude")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  foundation Foundation @relation(fields: [foundationId], references: [id], onDelete: Cascade)
  needs      Need[]

  @@index([foundationId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("campaigns")
}

model Need {
  id                String       @id @default(uuid()) @db.Uuid
  campaignId        String       @map("campaign_id") @db.Uuid
  name              String
  description       String?
  quantity          Int
  unit              String
  priority          NeedPriority @default(MEDIUM)
  fulfilledQuantity Int          @default(0) @map("fulfilled_quantity")
  deletedAt         DateTime?    @map("deleted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([campaignId])
  @@index([priority])
  @@map("needs")
}

model Donation {
  id                   String         @id @default(uuid()) @db.Uuid
  needId               String         @map("need_id") @db.Uuid
  donorUserId          String         @map("donor_user_id") @db.Uuid
  status               DonationStatus @default(COMMITTED)
  quantity             Int
  notes                String?
  estimatedDeliveryAt  DateTime?      @map("estimated_delivery_at")
  deliveryAddress      String?        @map("delivery_address")
  deliveryLatitude     Float?         @map("delivery_latitude")
  deliveryLongitude    Float?         @map("delivery_longitude")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  need         Need                    @relation(fields: [needId], references: [id], onDelete: Cascade)
  donor        User                    @relation("DonationDonor", fields: [donorUserId], references: [id], onDelete: Cascade)
  statusHistory DonationStatusHistory[]
  conversation Conversation?

  @@index([needId])
  @@index([donorUserId])
  @@index([status])
  @@map("donations")
}

model DonationStatusHistory {
  id          String          @id @default(uuid()) @db.Uuid
  donationId  String          @map("donation_id") @db.Uuid
  fromStatus  DonationStatus? @map("from_status")
  toStatus    DonationStatus  @map("to_status")
  changedById String?         @map("changed_by_id") @db.Uuid
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at")

  donation  Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  changedBy User?    @relation("DonationStatusChanger", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([donationId, createdAt])
  @@map("donation_status_history")
}

model Conversation {
  id         String   @id @default(uuid()) @db.Uuid
  donationId String   @unique @map("donation_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  donation Donation  @relation(fields: [donationId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Notification {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  type         NotificationType
  title        String
  body         String
  linkPath     String?          @map("link_path")
  resourceType String?          @map("resource_type")
  resourceId   String?          @map("resource_id") @db.Uuid
  isRead       Boolean          @default(false) @map("is_read")
  readAt       DateTime?        @map("read_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@map("notifications")
}
